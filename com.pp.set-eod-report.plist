<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>

  <!-- Job label -->
  <key>Label</key>
  <string>com.pp.set-eod-report</string>

  <!-- Afternoon session + EOD report -->
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>/Users/_pporpin_/Documents/Claude/Projects/Stock/run_afternoon.sh</string>
  </array>

  <!-- Run at 14:25 Bangkok, Monday–Friday -->
  <key>StartCalendarInterval</key>
  <array>
    <dict><key>Weekday</key><integer>1</integer><key>Hour</key><integer>14</integer><key>Minute</key><integer>25</integer></dict>
    <dict><key>Weekday</key><integer>2</integer><key>Hour</key><integer>14</integer><key>Minute</key><integer>25</integer></dict>
    <dict><key>Weekday</key><integer>3</integer><key>Hour</key><integer>14</integer><key>Minute</key><integer>25</integer></dict>
    <dict><key>Weekday</key><integer>4</integer><key>Hour</key><integer>14</integer><key>Minute</key><integer>25</integer></dict>
    <dict><key>Weekday</key><integer>5</integer><key>Hour</key><integer>14</integer><key>Minute</key><integer>25</integer></dict>
  </array>

  <!-- Logs -->
  <key>StandardOutPath</key>
  <string>/Users/_pporpin_/Documents/Claude/Projects/Stock/logs/afternoon_session.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/_pporpin_/Documents/Claude/Projects/Stock/logs/afternoon_session_err.log</string>

  <key>KeepAlive</key>
  <false/>

  <key>RunAtLoad</key>
  <false/>

</dict>
</plist>
